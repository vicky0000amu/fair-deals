<%- include('partials/header', { title: 'My Orders' }) %>

<section class="section">
  <h2 class="section-title">My Orders</h2>

  <% if (orders.length === 0) { %>
    <div class="empty-state">
      <h2>No orders yet</h2>
      <a href="/products" class="btn">Start Shopping</a>
    </div>
  <% } else { %>
    <% orders.forEach(function(order) { %>
      <div class="order-card">
        <div class="order-header">
          <div>
            <strong>Order #<%= order.id.slice(0,8) %></strong><br>
            <span style="color: var(--color-text-muted);"><%= new Date(order.created_at).toLocaleDateString() %></span>
          </div>
          <div class="status-badge"><%= order.status %></div>
        </div>
        <% order.order_items.forEach(function(item) { %>
          <div class="order-item-row">
            <span><%= item.product_name %> x <%= item.quantity %></span>
            <span>Rs. <%= (item.price * item.quantity).toFixed(2) %></span>
          </div>
        <% }); %>
        <div class="order-item-row" style="margin-top:10px; padding-top:10px; border-top:1px solid var(--color-border); color: var(--color-gold); font-weight:600;">
          <span>Total</span>
          <span>Rs. <%= Number(order.total_amount).toFixed(2) %></span>
        </div>
      </div>
    <% }); %>
  <% } %>
</section>

<%- include('partials/footer') %>
