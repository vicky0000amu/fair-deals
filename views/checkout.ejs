<%- include('partials/header', { title: 'Checkout' }) %>

<section class="section">
  <h2 class="section-title">Checkout</h2>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="form-wrap">
    <h2 style="font-size:20px;">Shipping Details</h2>

    <form id="checkoutForm" action="/checkout" method="POST">

      <div class="form-group">
        <label for="shipping_name">Full Name</label>
        <input
          type="text"
          id="shipping_name"
          name="shipping_name"
          value="<%= user.name %>"
          required
        >
      </div>

      <div class="form-group">
        <label for="shipping_phone">Phone</label>
        <input
          type="text"
          id="shipping_phone"
          name="shipping_phone"
          value="<%= user.phone || '' %>"
          required
        >
      </div>

      <div class="form-group">
        <label for="shipping_address">Address</label>
        <textarea
          id="shipping_address"
          name="shipping_address"
          rows="3"
          required
        ><%= user.address || '' %></textarea>
      </div>

      <div class="cart-summary" style="margin-left:0;">
        <div class="cart-summary-row total">
          <span>Order Total</span>
          <span>Rs. <%= total.toFixed(2) %></span>
        </div>
      </div>

      <!-- COD -->
      <button
        type="submit"
        class="btn btn-solid btn-full"
        style="margin-bottom:15px;"
      >
        Place Order (Cash on Delivery)
      </button>

      <!-- Razorpay -->
      <button
        type="button"
        id="rzp-button"
        class="btn btn-outline btn-full"
      >
        Pay Online with Razorpay
      </button>

    </form>
  </div>
</section>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>

document.getElementById('rzp-button').onclick = async function () {

    const shipping_name =
      document.getElementById('shipping_name').value;

    const shipping_phone =
      document.getElementById('shipping_phone').value;

    const shipping_address =
      document.getElementById('shipping_address').value;

    if (
      !shipping_name ||
      !shipping_phone ||
      !shipping_address
    ) {
      alert('Please fill all shipping details');
      return;
    }

    const response = await fetch('/checkout/create-order', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      }
    });

    const order = await response.json();

    const options = {

      key: 'rzp_test_T1Zbu1533G6fxB',

      amount: order.amount,

      currency: order.currency,

      name: 'Fair Deals',

      description: 'Jewellery Purchase',

      order_id: order.id,

      handler: async function (response) {

        const verifyResponse = await fetch(
          '/checkout/verify-payment',
          {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({

              razorpay_order_id:
                response.razorpay_order_id,

              razorpay_payment_id:
                response.razorpay_payment_id,

              razorpay_signature:
                response.razorpay_signature,

              shipping_name,
              shipping_phone,
              shipping_address

            })
          }
        );

        const result =
          await verifyResponse.json();

        if (result.success) {

          window.location.href =
            '/checkout/payment-success';

        } else {

          alert('Payment verification failed');

        }
      },

      prefill: {
        name: shipping_name,
        contact: shipping_phone
      },

      theme: {
        color: '#d4af37'
      }
    };

    const rzp = new Razorpay(options);

    rzp.open();
};

</script>

<%- include('partials/footer') %>