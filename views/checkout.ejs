<%- include('partials/header', { title: 'Checkout' }) %>

<section class="section">
  <h2 class="section-title">Checkout</h2>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <div class="form-wrap">
    <h2 style="font-size:20px;">Shipping Details</h2>
    <form action="/checkout" method="POST">
      <div class="form-group">
        <label for="shipping_name">Full Name</label>
        <input type="text" id="shipping_name" name="shipping_name" value="<%= user.name %>" required>
      </div>
      <div class="form-group">
        <label for="shipping_phone">Phone</label>
        <input type="text" id="shipping_phone" name="shipping_phone" value="<%= user.phone || '' %>" required>
      </div>
      <div class="form-group">
        <label for="shipping_address">Address</label>
        <textarea id="shipping_address" name="shipping_address" rows="3" required><%= user.address || '' %></textarea>
      </div>

      <div class="cart-summary" style="margin-left:0;">
        <div class="cart-summary-row total">
          <span>Order Total</span>
          <span>Rs. <%= total.toFixed(2) %></span>
        </div>
      </div>

      <button type="submit" class="btn btn-solid btn-full">Place Order (Cash on Delivery)</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
