<%- include('partials/header', { title: 'Catalog' }) %>

<section class="section">
  <h2 class="section-title">Catalog</h2>

  <% if (products.length === 0) { %>

    <div class="empty-state">
      <h2>No products yet</h2>
      <p>Please check back soon.</p>
    </div>

  <% } else { %>

    <div class="product-grid">

      <% products.forEach(function(p) { %>

        <a href="/products/<%= p.slug %>" class="product-card">

          <% if (p.is_sold_out) { %>
            <span class="sold-out-badge">Sold Out</span>
          <% } %>

          <img
            class="product-card-img"
            src="<%= p.image_url %>"
            alt="<%= p.name %>"
          >

          <div class="product-card-body">

            <div class="product-card-title">
              <%= p.name %>
            </div>

            <div class="product-card-price">

              <% if (p.sale_price && Number(p.sale_price) > 0) { %>

                <span class="old-price">
                  Rs. <%= Number(p.price).toFixed(2) %>
                </span>

                Rs. <%= Number(p.sale_price).toFixed(2) %>

              <% } else { %>

                Rs. <%= Number(p.price).toFixed(2) %> INR

              <% } %>

            </div>

          </div>

        </a>

      <% }); %>

    </div>

  <% } %>
</section>

<%- include('partials/footer') %>